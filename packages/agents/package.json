{
  "name": "@creative-tim/agents",
  "version": "0.1.1",
  "description": "Official Creative Tim Agents SDK — programmatically create and control OpenClaw AI agents and other agent models",
  "author": {
    "name": "Creative Tim",
    "email": "hello@creative-tim.com",
    "url": "https://creative-tim.com"
  },
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["creative-tim", "openclaw", "ai", "agents", "sdk"],
  "devDependencies": {
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
