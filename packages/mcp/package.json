{
  "name": "@creative-tim/mcp",
  "version": "0.1.3",
  "description": "MCP server for Creative Tim OpenClaw — lets Claude Code, Cursor, Lovable and other AI tools spawn and control agents",
  "author": {
    "name": "Creative Tim",
    "email": "hello@creative-tim.com",
    "url": "https://creative-tim.com"
  },
  "license": "Apache-2.0",
  "type": "module",
  "exports": "./dist/index.js",
  "bin": {
    "creative-tim-mcp": "dist/index.js",
    "ct-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "creative-tim",
    "openclaw",
    "mcp",
    "ai",
    "agents",
    "claude",
    "cursor",
    "lovable"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@creative-tim/agents": "^0.1.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creativetimofficial/agents-sdk.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/creativetimofficial/agents-sdk/tree/main/packages/mcp",
  "bugs": {
    "url": "https://github.com/creativetimofficial/agents-sdk/issues"
  }
