{
  "name": "@creative-tim/mcp",
  "version": "0.1.1",
  "description": "MCP server for Creative Tim OpenClaw — lets Claude Code, Cursor, Lovable and other AI tools spawn and control agents",
  "author": {
    "name": "Creative Tim",
    "email": "hello@creative-tim.com",
    "url": "https://creative-tim.com"
  },
  "license": "Apache-2.0",
  "type": "module",
  "exports": "./dist/index.js",
  "bin": {
